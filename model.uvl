namespace EventManager

features
	EventManager
		mandatory
			UserAuthentication
			CheckIn {abstract true}
				optional
					ManualCheckIn
					TicketCheckIn
			EventCreation
			AttendeeManagement
		optional
			Payment
				or
					QRIS
					BankTransfer
			SeatSelection
			TicketingSystem

constraints
	TicketCheckIn => TicketingSystem

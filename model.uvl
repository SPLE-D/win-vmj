namespace EventManager

features
	EventManager
		mandatory
			Report
			Review
			CheckIn {abstract true}
				alternative
					ManualCheckIn
					TicketCheckIn
			EventCreation
			AttendeeManagement
		optional
			TicketingSystem
			Payment
				or
					QRIS
					BankTransfer
			Notification

constraints
	TicketCheckIn => TicketingSystem
